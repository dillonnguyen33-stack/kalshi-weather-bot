# Weatherquant environment template — copy to `.env` (never commit the real `.env`).
#
# DATABASE_URL MUST use the `postgresql+psycopg://` scheme (psycopg v3, NOT psycopg2).
# The plain `postgresql://` form would make SQLAlchemy default to psycopg2, which is
# forbidden and not installed (D-09 / Pitfall 4).
DATABASE_URL=postgresql+psycopg://USER:PASS@localhost:5432/weatherquant
