# Weatherquant environment template — copy to .env and fill in.
# .env is gitignored; NEVER commit real secrets or the RSA key material.

# ---- Database (required) -------------------------------------------------
# Must use the psycopg3 dialect exactly: postgresql+psycopg:// (D-09).
# A bare postgresql:// or postgresql+psycopg2:// URL is rejected at startup.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/weatherquant

# ---- Execution policy (D-15) — NOT a secret ------------------------------
# Locked set {paper, live}. This milestone (Gate 1) stays on paper.
EXECUTION_MODE=paper

# ---- Money-path policy (D-13) — NOT secrets ------------------------------
BANKROLL_USD=500.0
# Single-position cap; locked band [0.02, 0.05].
MAX_POSITION_FRACTION=0.02

# ---- Kalshi credentials (Phase 5, D-14) — SECRETS -----------------------
# RSA-PSS auth (RSA-SHA256 / PSS over timestamp+method+path).
# KALSHI_KEY_ID           = the Access Key ID (UUID) from the Kalshi API key page.
# KALSHI_PRIVATE_KEY_PATH = filesystem PATH to the PEM file OUTSIDE the repo
#                           (never paste the key material here; loss is
#                           irrecoverable, leak is account-level access).
# Use the demo account at demo.kalshi.co for paper testing (separate keys
# from prod). The client targets the demo hosts by default.
DEMO_KALSHI_KEY_ID=
DEMO_KALSHI_PRIVATE_KEY_PATH=

KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# ---- Ingestion secrets (Phase 2) — optional, degrade gracefully (D-11) ---
# Absent keys make the AFD/Wethr clients skip rather than fail.
ANTHROPIC_API_KEY=
WETHR_API_KEY=

# ---- Live cross-check overrides (test-only, optional) --------------------
# Point the D-16 KXHIGH live cross-check at a currently-open market.
# KXHIGH_CROSSCHECK_TICKER=KXHIGHNY
# Leave unset to use the safe demo host; set to 1 to force the prod host.
# KXHIGH_CROSSCHECK_PROD=1
